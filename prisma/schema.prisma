// =============================================
// GESAP - Esquema de Base de Datos (Prisma)
// Cada modelo representa una tabla en PostgreSQL
// =============================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- ROLES DEL SISTEMA ----
model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(30)
  description String?  @db.VarChar(150)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

// ---- USUARIOS DEL SISTEMA ----
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  firstName String   @map("first_name") @db.VarChar(50)
  lastName  String   @map("last_name") @db.VarChar(50)
  roleId    Int      @map("role_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role           Role            @relation(fields: [roleId], references: [id])
  medicalRecords MedicalRecord[]
  treatments     Treatment[]

  @@map("users")
}

// ---- PACIENTES ----
// Nombre completo segun formato guatemalteco: hasta 3 nombres y 2 apellidos
model Patient {
  id             Int       @id @default(autoincrement())
  dpi            String    @unique @db.VarChar(13)
  firstName      String    @map("first_name") @db.VarChar(50)
  secondName     String?   @map("second_name") @db.VarChar(50)
  thirdName      String?   @map("third_name") @db.VarChar(50)
  firstLastName  String    @map("first_last_name") @db.VarChar(50)
  secondLastName String    @map("second_last_name") @db.VarChar(50)
  birthDate      DateTime  @map("birth_date") @db.Date
  sex            Sex
  bloodType      BloodType? @map("blood_type")
  phone          String?   @db.VarChar(8)
  address        String?   @db.VarChar(255)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  allergies         Allergy[]
  medicalRecords    MedicalRecord[]
  treatments        Treatment[]
  emergencyContacts EmergencyContact[]

  @@map("patients")
}

// ---- CONTACTOS DE EMERGENCIA ----
// Cada paciente puede tener hasta 5 contactos de emergencia
model EmergencyContact {
  id          Int      @id @default(autoincrement())
  patientId   Int      @map("patient_id")
  fullName    String   @map("full_name") @db.VarChar(100)
  phone       String   @db.VarChar(8)
  relationship String? @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("emergency_contacts")
}

// ---- ALERGIAS ----
model Allergy {
  id          Int             @id @default(autoincrement())
  patientId   Int             @map("patient_id")
  substance   String          @db.VarChar(100)
  type        AllergyType
  severity    AllergySeverity
  notes       String?         @db.VarChar(255)
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("allergies")
}

// ---- EXPEDIENTE MEDICO ----
model MedicalRecord {
  id          Int      @id @default(autoincrement())
  patientId   Int      @map("patient_id")
  doctorId    Int      @map("doctor_id")
  diagnosis   String   @db.Text
  notes       String?  @db.Text
  vitalSigns  Json?    @map("vital_signs")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  User    @relation(fields: [doctorId], references: [id])

  @@map("medical_records")
}

// ---- TRATAMIENTOS ----
model Treatment {
  id          Int      @id @default(autoincrement())
  patientId   Int      @map("patient_id")
  doctorId    Int      @map("doctor_id")
  name        String   @db.VarChar(150)
  description String?  @db.Text
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  User    @relation(fields: [doctorId], references: [id])

  @@map("treatments")
}

// ---- CUENTAS DE PACIENTES ----
model PatientAccount {
  id          Int      @id @default(autoincrement())
  dpi         String   @unique @db.VarChar(13)
  email       String   @unique @db.VarChar(100)
  password    String   @db.VarChar(255)
  status      AccountStatus @default(PENDING)
  approvedBy  Int?     @map("approved_by")
  approvedAt  DateTime? @map("approved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("patient_accounts")
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---- ENUMS ----

enum Sex {
  MASCULINO
  FEMENINO
}

enum BloodType {
  A_POSITIVO  @map("A+")
  A_NEGATIVO  @map("A-")
  B_POSITIVO  @map("B+")
  B_NEGATIVO  @map("B-")
  AB_POSITIVO @map("AB+")
  AB_NEGATIVO @map("AB-")
  O_POSITIVO  @map("O+")
  O_NEGATIVO  @map("O-")
}

enum AllergyType {
  MEDICATION
  FOOD
  ENVIRONMENTAL
  OTHER
}

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
}
